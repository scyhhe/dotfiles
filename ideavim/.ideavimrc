:map <c-n> <Action>(SearchEverywhere)
:map <leader>ff <Action>(GotoFile)
:map <c-b> <Action>(ShowUsages)
:map <c-s> <Action>(SaveAll)
:map <c-c> <Action>(GotoImplementation)

